-- Targeting / whitelist
local function sameParty(p)
    local a, b = lp:FindFirstChild("Party"), p:FindFirstChild("Party")
    return a and b and a.Value == b.Value
end
local function isWhitelisted(p)
    if whitelist[p.UserId] then return true end
    if flags.whitelistParty and sameParty(p) then return true end
    local ok, res = pcall(function() return lp:IsFriendsWith(p.UserId) end)
    if ok and res and flags.whitelistParty then return true end
    return false
end
local function validEnemy(p, char)
    if p == lp or not char then return false end
    if isWhitelisted(p) then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hv = p:FindFirstChild("Health")
    if hv and hv.Value <= 0 then return false end
    return hrp ~= nil and hum ~= nil and hum.Health > 0
end
local function nearest(range)
    local myC = lp.Character
    local myHRP = myC and myC:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    local best, bestD = nil, range or math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        local c = p.Character
        if validEnemy(p, c) then
            local hrp = c:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = (myHRP.Position - hrp.Position).Magnitude
                if d < bestD then best, bestD = c, d end
            end
        end
    end
    return best
end

-- Combat helpers (real server contract: hits/slam require the "guarding" tag)
local function guard() Combat:FireServer("guarding") end
