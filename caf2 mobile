local function startESPForPlayer(player)
    if player == lp then return end
    if isWhitelisted(player) then stopESPForPlayer(player); return end
    espData[player] = espData[player] or {}
    local data = espData[player]
    if data._monitorRunning then return end
    data._monitorRunning = true
    task.spawn(function()
        while data._monitorRunning and flags.esp do
            local char = player.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
                if hum and hrp and (not data.highlight or not data.highlight.Parent) then
                    createChamsAndHud(player, hrp, hum)
                end
            end
            task.wait(0.2)
        end
    end)
end
function stopESPForPlayer(player)
    local data = espData[player]
    if not data then return end
    data._monitorRunning = false
    safeDisconnect(data.humConn); safeDisconnect(data.diedConn); safeDisconnect(data.charAddedRespawnConn)
    pcall(function() if data.hud then data.hud:Destroy() end end)
    pcall(function() if data.highlight then data.highlight:Destroy() end end)
    espData[player] = nil
end
local function enableESPAll() for _, p in ipairs(Players:GetPlayers()) do if p ~= lp then startESPForPlayer(p) end end end
local function disableESPAll() for p, _ in pairs(espData) do stopESPForPlayer(p) end end
