-- Block animation: play the style's Block anim so the block stance shows (server-side block is just a tag).
local CombatAnims = ReplicatedStorage:FindFirstChild("Animations") and ReplicatedStorage.Animations:FindFirstChild("Combat")
local blockTrack = nil
local function styleBlockAnim()
    if not CombatAnims then return nil end
    local sv = lp:FindFirstChild("leaderstats") and lp.leaderstats:FindFirstChild("Style")
    local name = (sv and sv.Value) or "Default"
    local folder
    for _, f in ipairs(CombatAnims:GetChildren()) do
        if f:IsA("Folder") and f.Name:lower() == name:lower() then folder = f; break end
    end
    folder = folder or CombatAnims:FindFirstChild("Default")
    return folder and folder:FindFirstChild("Block")
end
local function playBlockAnim()
    pcall(function()
        if blockTrack and blockTrack.IsPlaying then return end
        local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
        local animator = hum and hum:FindFirstChildOfClass("Animator")
        local anim = styleBlockAnim()
        if animator and anim then blockTrack = animator:LoadAnimation(anim); blockTrack.Priority = Enum.AnimationPriority.Action; blockTrack:Play(0.08) end
    end)
end
local function stopBlockAnim() if blockTrack then pcall(function() blockTrack:Stop(0.15) end); blockTrack = nil end end

-- Safe Mode: play your real punch animation (alternating L/R of the equipped style) as kill aura fires.
local punchToggle = false
local function playPunchAnim()
    pcall(function()
        if not CombatAnims then return end
        local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
        local animator = hum and hum:FindFirstChildOfClass("Animator")
        if not animator then return end
        local sv = lp:FindFirstChild("leaderstats") and lp.leaderstats:FindFirstChild("Style")
        local name = (sv and sv.Value) or "Default"
        local folder
        for _, f in ipairs(CombatAnims:GetChildren()) do
            if f:IsA("Folder") and f.Name:lower() == name:lower() then folder = f; break end
        end
        folder = folder or CombatAnims:FindFirstChild("Default")
        punchToggle = not punchToggle
        local anim = folder and (punchToggle and folder:FindFirstChild("L") or folder:FindFirstChild("R"))
        if anim then local t = animator:LoadAnimation(anim); t.Priority = Enum.AnimationPriority.Action; t:Play() end
    end)
end

local function killAuraHit(targetChar)
    blockSuppressUntil = tick() + 0.12   -- let the hit land before auto-block re-engages
    if isBlocking then Combat:FireServer("unblock"); isBlocking = false; stopBlockAnim(); task.wait(0.02) end
    guard(); fists()
    Combat:FireServer(flags.kaHead and "head" or "body", targetChar, false)
    if flags.kaSafe then playPunchAnim() end
end
local function slamTarget(targetChar) guard(); Combat:FireServer("slam", targetChar) end

-- Auto block: fire "block" ONCE per engage (server rate-limits it to 0.05s, so spamming it
-- every frame means the blocking tag never applies). Re-fire only to recover from breaks.
local function block()
    local c = lp.Character; if not c then return end
    if not c:HasTag("guarding") then guard() end
    local now = tick()
    if not isBlocking then
        fists(); Combat:FireServer("block"); isBlocking = true; lastBlockFire = now; playBlockAnim()
    elseif not c:HasTag("blocking") and now - lastBlockFire > 0.15 then
        Combat:FireServer("block"); lastBlockFire = now
    end
end
local function unblock() if isBlocking then isBlocking = false; Combat:FireServer("unblock"); stopBlockAnim() end end

-- Reactive auto-block detection. Replicated tracks lose their Name, so match attacks by
-- AnimationId (set from the Combat folder). Nearby enemy attack arms a brief block window;
-- your own attack releases the block so your hit lands.
local attackIds = {}
if CombatAnims then
    for _, d in ipairs(CombatAnims:GetDescendants()) do
        if d:IsA("Animation") then
            local n = d.Name:lower()
            if n == "l" or n == "r" or n == "head" or n == "grab" or n:find("kick") or n:find("groundpunch") then
                attackIds[d.AnimationId] = true
            end
        end
    end
end
local function hookAttacks(p)
    local function hookChar(char)
        local hum = char:WaitForChild("Humanoid", 10)
        local animator = hum and hum:WaitForChild("Animator", 10)
        if not animator then return end
        animator.AnimationPlayed:Connect(function(track)
            local a = track.Animation
            if not (a and attackIds[a.AnimationId]) then return end
            if p == lp then
                blockSuppressUntil = tick() + 0.5; unblock()
            else
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local myC = lp.Character
                local mh = myC and myC:FindFirstChild("HumanoidRootPart")
                if hrp and mh and (mh.Position - hrp.Position).Magnitude <= flags.blockRange then
                    lastIncoming = tick()
                end
            end
        end)
    end
    if p.Character then task.spawn(hookChar, p.Character) end
    p.CharacterAdded:Connect(hookChar)
end
for _, p in ipairs(Players:GetPlayers()) do hookAttacks(p) end
Players.PlayerAdded:Connect(hookAttacks)

