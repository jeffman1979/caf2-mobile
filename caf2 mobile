-- Anti-ragdoll / godmode / noclip enforcement
local function clearRagdoll(char)
    if not char then return end
    local trig = char:FindFirstChild("RagdollTrigger")
    if trig and trig:IsA("BoolValue") and trig.Value then trig.Value = false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        if hum:GetAttribute("RagdollEnabled") then hum:SetAttribute("RagdollEnabled", false) end
        hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
        if hum.PlatformStand then hum.PlatformStand = false end
        local st = hum:GetState()
        if st == Enum.HumanoidStateType.Physics or st == Enum.HumanoidStateType.Ragdoll then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
end
RunService.Stepped:Connect(function()
    local char = lp.Character
    if not char then return end
    if flags.antiRagdoll or flags.antiKnockdown or flags.godmode then clearRagdoll(char) end
    if flags.godmode then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then if hum.MaxHealth < 1e6 then hum.MaxHealth = 1e6 end; hum.Health = hum.MaxHealth end
    end
    if flags.noclip then
        for _, p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") and p.CanCollide then p.CanCollide = false end end
    end
end)

-- Main combat loop
RunService.Heartbeat:Connect(function()
    local now = tick()
    local myC = lp.Character
    if not myC then return end
    local myHRP = myC:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    lockTarget = nearest(math.max(flags.killRange, flags.slamRange))

    if flags.infStamina then
        local ms, sr = lp:FindFirstChild("MaxStamina"), lp:FindFirstChild("StaminaRegen")
        if ms and ms.Value < 1e6 then ms.Value = 1e6 end
        if sr and sr.Value < 1e4 then sr.Value = 1e4 end
    end

    if flags.killAura and now - lastKill >= math.max(flags.killAuraCD, 0.1) then
        local t = nearest(flags.killRange)
        if t then lastKill = now; task.spawn(killAuraHit, t) end
    end

    if flags.autoSlam and now - lastSlam >= SLAM_CD then
        if not myC:HasTag("slamming") and not myC:HasTag("slammed") then
            local t = nearest(math.min(flags.slamRange, 10))
            if t and not t:HasTag("slammed") then lastSlam = now; task.spawn(slamTarget, t) end
        end
    end

    if flags.autoBlock then
        if now >= blockSuppressUntil and now - lastIncoming <= 0.6 then block() else unblock() end
    elseif isBlocking then unblock() end

    -- purple lock highlight
    if flags.showLocked and lockTarget and lockTarget.Parent then lockHL.Adornee = lockTarget; lockHL.Enabled = true
    else lockHL.Enabled = false; lockHL.Adornee = nil end
end)

