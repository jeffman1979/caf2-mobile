    end

    data.highlight = hl; data.hud = bg; data.frame = frame; data.nameLbl = nameLbl; data.barFill = barFill; data.hpText = hpText; data.humRef = hum

    local function applyHealth(h)
        local maxH = (hum.MaxHealth and hum.MaxHealth > 0) and hum.MaxHealth or 100
        local pct = math.clamp((h or 0) / maxH, 0, 1)
        local col = healthColor(pct)
        if data.highlight then pcall(function() data.highlight.FillColor = col; data.highlight.OutlineColor = col end) end
        if data.barFill and data.barFill.Parent then pcall(function() data.barFill.Size = UDim2.new(pct, 0, 1, 0); data.barFill.BackgroundColor3 = col end) end
        if data.hpText and data.hpText.Parent then pcall(function() data.hpText.Text = tostring(math.max(0, math.floor(h or 0))) end) end
    end
    if hum then applyHealth(hum.Health) end
    safeDisconnect(data.humConn); safeDisconnect(data.diedConn)
    if hum then
        data.humConn = hum.HealthChanged:Connect(applyHealth)
        data.diedConn = hum.Died:Connect(function()
            if data.barFill and data.barFill.Parent then data.barFill.Size = UDim2.new(0, 0, 1, 0) end
            if data.hud and data.hud.Parent then pcall(function() data.hud:Destroy() end) end
